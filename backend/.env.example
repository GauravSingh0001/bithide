# BitHide Backend Environment Configuration
# Copy this to .env and fill in your values

# ─── Flask ───────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=false
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY_32_CHARS

# ─── File Handling ────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50
UPLOAD_FOLDER=/tmp/bithide_uploads
OUTPUT_FOLDER=/tmp/bithide_outputs

# ─── Security ────────────────────────────────────────────────────────────────
MAX_MESSAGE_LENGTH=5000
MIN_KEY_LENGTH=8

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=30 per minute
RATE_LIMIT_ENCODE=10 per minute
RATE_LIMIT_DECODE=10 per minute
# For production Redis: redis://localhost:6379/0
RATE_LIMIT_STORAGE=memory://

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of trusted frontend origins
CORS_ORIGINS=http://localhost:5173

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/bithide.log

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
